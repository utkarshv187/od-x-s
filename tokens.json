{
  "$meta": {
    "name": "Centricity OD×S — One App tokens",
    "version": "0.1.0",
    "theme": "dark-first",
    "frame": "375x812 iPhone",
    "sources": {
      "sentinel": "https://sentinel-partner.centricitywealth.tech (live CSS variables, extracted 2026-07-17)",
      "centricity-ds": "~/Desktop/centricity-design-system (296 vars materialized from claude.fig)",
      "brand-figma": "hekJWgSTwAaHJZqdgjhkMS — PENDING ACCESS; tokens below to be reconciled once shared",
      "brief": "Negative financial values #931621; base ~#050608; 16-24px radii"
    }
  },
  "color": {
    "surface": {
      "canvas": { "value": "#050608", "comment": "Sentinel --bg-root; app background" },
      "raised": { "value": "#0D1017", "comment": "Sentinel --panel; first elevation" },
      "card": { "value": "#14181F", "comment": "Sentinel --inset; card body" },
      "sheet": { "value": "#1A1F28", "comment": "bottom sheets / modals" },
      "hover": { "value": "#1F242E", "comment": "row hover / focus surface" },
      "pressed": { "value": "#252B36", "comment": "pressed state" },
      "glass": { "value": "rgba(13,16,23,0.72)", "comment": "frosted tab bar / floating pills, blur 20" },
      "overlay": { "value": "rgba(3,4,6,0.70)", "comment": "scrim behind sheets" },
      "input": { "value": "#0D1017" }
    },
    "text": {
      "primary": { "value": "#FAFAF7" },
      "secondary": { "value": "#B4BFD0" },
      "tertiary": { "value": "#7B8699" },
      "faint": { "value": "#60706F" },
      "disabled": { "value": "rgba(255,255,255,0.35)" },
      "onAccent": { "value": "#0B1220", "comment": "ink label on gold CTA — never white" },
      "heroNumeral": { "value": "#F7F4EA", "comment": "cream, Tabular figures, ₹ Indian grouping" }
    },
    "accent": {
      "gold500": { "value": "#B89E55", "comment": "Sentinel entry gold — primary brand accent" },
      "gold400": { "value": "#D4BF7B", "comment": "gold soft / hover" },
      "gold600": { "value": "#8F7A3E", "comment": "pressed" },
      "goldTint": { "value": "rgba(184,158,85,0.14)", "comment": "selected chip bg" },
      "goldBorder": { "value": "rgba(184,158,85,0.34)", "comment": "focused / selected border" },
      "metalCTA": { "value": "linear-gradient(169.66deg,#F2E6CE -117%,#D8BC9C -37%,#B89E55 50%,#8F7A3E 124%,#C9A888 218%)", "comment": "brushed-metal primary CTA, one per screen, ink label" },
      "aiGradient": { "value": "linear-gradient(135deg,#4A6CFF,#8B5CF6)", "comment": "AI / NBA / digital-advisor moments only" },
      "blue": { "value": "#4A6CFF", "comment": "interactive links, focus ring, info" }
    },
    "module": {
      "acquire": { "value": "#6366F1" },
      "manage": { "value": "#10B981" },
      "discover": { "value": "#A855F7" },
      "serve": { "value": "#F59E0B" },
      "insights": { "value": "#06B6D4" },
      "comment": "wayfinding tints from Sentinel — used at 14-18% alpha on chips/section headers, never as large fills"
    },
    "data": {
      "positive": { "value": "#10B981" },
      "negative": { "value": "#931621", "comment": "brief-mandated negative financial value color" },
      "negativeOnDark": { "value": "#E4536B", "comment": "legibility companion — small negative text on dark cards; #931621 reserved for fills/badges/large numerals" },
      "warning": { "value": "#D97706" },
      "info": { "value": "#4A6CFF" },
      "chart": ["#10B981", "#4A6CFF", "#8B5CF6", "#D97706", "#0891B2", "#B89E55", "#E4536B"],
      "tier": { "t0": "#10B981", "t1": "#4A6CFF", "t2": "#D97706", "t3": "#E53E3E" }
    },
    "border": {
      "subtle": { "value": "rgba(255,255,255,0.03)" },
      "default": { "value": "rgba(255,255,255,0.06)" },
      "strong": { "value": "rgba(255,255,255,0.12)" },
      "hairlineTop": { "value": "rgba(255,255,255,0.09)", "comment": "1px inner top highlight on glass" },
      "focus": { "value": "rgba(99,131,255,0.5)" }
    }
  },
  "typography": {
    "fontFamily": {
      "ui": { "value": "Figtree", "comment": "brand UI font (Google Font, available in Figma); Sentinel web uses Inter — Figtree wins as brand font per DS repo" },
      "numeral": { "value": "Tabular", "comment": "custom brand font (~/Desktop/centricity-design-system/fonts). All ₹ values, scores, returns. Fallback: Figtree + tabular-nums" },
      "micro": { "value": "JetBrains Mono", "comment": "UPPERCASE micro data-labels (3Y CAGR, AUM, SCORE); Sentinel-aligned" }
    },
    "scale": {
      "display": { "size": 34, "lineHeight": 40, "weight": 700, "family": "ui", "comment": "hero numerals use family=numeral" },
      "h1": { "size": 28, "lineHeight": 34, "weight": 700, "family": "ui" },
      "h2": { "size": 22, "lineHeight": 28, "weight": 600, "family": "ui" },
      "h3": { "size": 18, "lineHeight": 24, "weight": 600, "family": "ui" },
      "bodyLg": { "size": 16, "lineHeight": 24, "weight": 400, "family": "ui" },
      "body": { "size": 14, "lineHeight": 20, "weight": 400, "family": "ui" },
      "caption": { "size": 12, "lineHeight": 16, "weight": 400, "family": "ui" },
      "microLabel": { "size": 10, "lineHeight": 14, "weight": 500, "family": "micro", "tracking": 1.2, "case": "upper" },
      "numLg": { "size": 24, "lineHeight": 30, "weight": 600, "family": "numeral" },
      "num": { "size": 14, "lineHeight": 20, "weight": 500, "family": "numeral" },
      "numSm": { "size": 12, "lineHeight": 16, "weight": 500, "family": "numeral" }
    }
  },
  "spacing": { "xs": 4, "sm": 8, "md": 12, "lg": 16, "xl": 20, "2xl": 24, "3xl": 32, "4xl": 40, "5xl": 48, "gutter": 16, "cardGap": 12 },
  "radius": { "xs": 6, "sm": 10, "md": 14, "lg": 16, "xl": 20, "2xl": 24, "pill": 999, "comment": "cards 16-20, sheets 24 top, chips pill — per brief 16-24 range" },
  "elevation": {
    "card": { "value": "0 1px 2px rgba(0,0,0,0.3), 0 2px 8px rgba(0,0,0,0.25)" },
    "raised": { "value": "0 4px 12px rgba(0,0,0,0.4)" },
    "overlay": { "value": "0 12px 28px -12px rgba(0,0,0,0.5)" },
    "glow": { "value": "0 0 24px rgba(184,158,85,0.18)", "comment": "one gold rim-glow per screen max" },
    "blur": { "glass": 20 }
  },
  "motion": {
    "duration": { "fast": 120, "base": 220, "slow": 400 },
    "easing": { "standard": "cubic-bezier(0.4,0,0.2,1)", "outExpo": "cubic-bezier(0.16,1,0.3,1)", "spring": "cubic-bezier(0.34,1.56,0.64,1)" }
  }
}
